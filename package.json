{
  "name": "ruleset",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["packages/*"],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "TEST_SKIP_SETUP=1 vitest run tests/unit src/lib",
    "test:api": "vitest run tests/api",
    "test:pages": "vitest run tests/pages",
    "test:ui": "playwright test",
    "test:all": "vitest run && playwright test",
    "test:ci": "next build && vitest run",
    "db:seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.1023.0",
    "@aws-sdk/s3-request-presigner": "^3.1023.0",
    "@hookform/resolvers": "^5.2.2",
    "@lemonsqueezy/lemonsqueezy.js": "^4.0.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@react-email/components": "^1.0.10",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^17.4.0",
    "framer-motion": "^12.33.0",
    "lucide-react": "^0.563.0",
    "next": "16.2.2",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.8.2",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.1",
    "resend": "^6.10.0",
    "server-only": "^0.0.1",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prisma": "^7.6.0",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
